# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1YOUR_TWILIO_NUMBER

# Pretty Good AI assessment number. Do not change unless instructed by Pretty Good AI.
TARGET_PHONE_NUMBER=+18054398008

# Public URL for your local server, e.g. ngrok URL without trailing slash
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app

# OpenAI, used for patient replies, transcript analysis, and optional transcription
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_LIVE_MAX_TOKENS=40
OPENAI_LIVE_TIMEOUT_SEC=1.2
LIVE_CONTEXT_TURNS=6

# Safety
MAX_TURNS_PER_CALL=10
